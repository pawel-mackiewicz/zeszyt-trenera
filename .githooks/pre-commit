#!/usr/bin/env sh
set -eu

staged_formattable_files() {
  # Keep auto-fixes scoped to the commit so a routine commit does not rewrite unrelated work.
  git diff --cached --name-only --diff-filter=ACMR -z -- \
    '*.js' '*.cjs' '*.mjs' '*.ts' '*.cts' '*.mts' '*.vue' \
    '*.json' '*.md' '*.css' '*.scss' '*.html' '*.yml' '*.yaml'
}

if ! staged_formattable_files | xargs -0 --no-run-if-empty pnpm run lint:fix --; then
  exit 1
fi

# Re-stage the files that the combined formatter and linter may have rewritten.
staged_formattable_files | xargs -0 --no-run-if-empty git add --
