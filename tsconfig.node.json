{
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "types": ["node"]
  },
  "include": [
    "vite.config.ts",
    "vitest.config.ts",
    // Why: Storybook 10 publishes its Vue/Vite config types through package exports, so main.ts needs the Node tooling project's Bundler resolution.
    ".storybook/main.ts",
    "eslint.config.mjs",
    "prettier.config.mjs"
  ]
}
