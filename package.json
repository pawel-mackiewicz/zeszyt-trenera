{
  "name": "zeszyt-trenera",
  "version": "0.6.9",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.4.0",
  "scripts": {
    "dev": "vite",
    "dev:e2e": "vite --host 127.0.0.1 --port 5173 --strictPort --mode e2e",
    "build": "vue-tsc --noEmit -p tsconfig.app.json && vite build",
    "preview": "pnpm run build && wrangler dev",
    "prepare": "pnpm run hooks:install",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json",
    "lint": "eslint .",
    "lint:fix": "sh scripts/run-lint-fix.sh",
    "hooks:install": "sh scripts/install-git-hooks.sh",
    "format": "sh scripts/run-prettier.sh",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "test:storybook": "vitest run --project storybook",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "deploy": "pnpm run build && wrangler deploy --env prod",
    "deploy:staging": "pnpm run build && wrangler deploy --env staging"
  },
  "dependencies": {
    "dexie": "^4.4.0",
    "dexie-export-import": "^4.4.0",
    "libphonenumber-js": "^1.12.40",
    "pinia": "^3.0.4",
    "uuid": "^13.0.0",
    "vue": "^3.5.30",
    "vue-i18n": "^11.3.0",
    "vue-router": "^4.6.4",
    "workbox-window": "^7.4.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@eslint/js": "^10.0.1",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/roboto-mono": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@intlify/unplugin-vue-i18n": "^11.0.7",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/vue3-vite": "^10.3.5",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/browser-playwright": "4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-storybook": "^10.3.5",
    "eslint-plugin-vue": "^10.8.0",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.4",
    "playwright": "^1.60.0",
    "prettier": "^3.8.1",
    "storybook": "^10.3.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.5",
    "wrangler": "^4.80.0"
  }
}
